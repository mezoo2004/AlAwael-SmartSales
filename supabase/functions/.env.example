# Server-side secrets for Supabase Edge Functions ONLY.
# Set via CLI (never commit real values):
#   supabase secrets set DESIGN_GENERATION_MODE=demo
#   # Later only — do not set yet:
#   # supabase secrets set OPENAI_API_KEY=sk-...
#
# NEVER add VITE_OPENAI_API_KEY.
# NEVER put these keys in React, Vite, browser code, or localStorage.
#
# DESIGN_GENERATION_MODE allowed values: demo | live
# Missing or invalid values default to demo on the server.

OPENAI_API_KEY=
DESIGN_GENERATION_MODE=demo
